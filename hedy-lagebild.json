      "parameters": {
        "jsCode": "const results = $input.first().json.results;\nlet oldest;\nif (results && results.length > 0) {\n  const lastDate = results[0].properties?.Datum?.date?.start;\n  oldest = lastDate ? String(new Date(lastDate).getTime() / 1000) : String(Math.floor(Date.now()/1000) - 86400);\n} else {\n  oldest = String(Math.floor(Date.now()/1000) - 86400);\n}\nreturn [{ json: { oldest } }];"
      }
